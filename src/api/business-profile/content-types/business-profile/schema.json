{
  "kind": "collectionType",
  "collectionName": "business_profiles",
  "info": {
    "singularName": "business-profile",
    "pluralName": "business-profiles",
    "displayName": "BusinessProfile"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "groupID": {
      "type": "uid"
    },
    "searchVisibility": {
      "type": "boolean",
      "required": false,
      "default": true
    },
    "matchingOptIn": {
      "type": "boolean",
      "required": false,
      "default": true
    },
    "allowInboundMessages": {
      "type": "boolean",
      "required": false,
      "default": true
    },
    "companyName": {
      "type": "string",
      "required": false
    },
    "registrationDate": {
      "type": "date"
    },
    "primaryTradeRole": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::trade-role.trade-role",
      "mappedBy": "tradeRole"
    },
    "annualTradeVolume": {
      "type": "enumeration",
      "enum": [
        "under_1m_hkd",
        "between_1m_and_5m_hkd",
        "between_5m_and_10m_hkd",
        "between_10m_and_50m_hkd",
        "over_500m_hkd"
      ]
    },
    "topProductCategories": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::industry.industry",
      "mappedBy": "productCategory"
    },
    "selfReportedTradeMarkets": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::country-origin.country-origin",
      "mappedBy": "tradeMarket"
    },
    "companySize": {
      "type": "enumeration",
      "enum": [
        "one_to_ten",
        "eleven_to_one_hundred",
        "one_hundred_one_to_five_hundred",
        "over_five_hundred"
      ]
    },
    "mainlandChinaPresence": {
      "type": "boolean",
      "default": false
    },
    "companyDescription": {
      "type": "text",
      "maxLength": 500,
      "required": false
    },
    "companyLogo": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "relatedIndustries": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::industry.industry",
      "mappedBy": "industry"
    },
    "lastActivity": {
      "type": "enumeration",
      "enum": [
        "last_7_days",
        "last_30_days",
        "last_90_days",
        "over_90_days"
      ]
    },
    "totalDeclarations": {
      "type": "enumeration",
      "enum": [
        "under_10m_hkd",
        "between_10m_and_50m_hkd",
        "between_50m_and_200m_hkd",
        "over_200m_hkd"
      ]
    },
    "lastYearDeclarations": {
      "type": "enumeration",
      "enum": [
        "under_1m_hkd",
        "between_1m_and_5m_hkd",
        "between_5m_and_10m_hkd",
        "between_10m_and_50m_hkd",
        "over_500m_hkd"
      ]
    },
    "hsCodeCategory": {
      "type": "biginteger"
    },
    "hkDistrictLocation": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::hk-district.hk-district"
    },
    "averageTransactionValue": {
      "type": "enumeration",
      "enum": [
        "under_10m_hkd",
        "between_10m_and_50m_hkd",
        "between_50m_and_200m_hkd",
        "over_200m_hkd"
      ]
    },
    "trustLevel": {
      "type": "enumeration",
      "required": false,
      "enum": [
        "verified",
        "basic"
      ]
    },
    "highVolumeTrader": {
      "type": "boolean",
      "default": false
    },
    "highValueTrader": {
      "type": "boolean",
      "default": false
    },
    "longTermMember": {
      "type": "boolean",
      "default": false
    },
    "companyProductListing": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::company-product.company-product",
      "mappedBy": "product"
    },
    "businessProfiles": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::business-profile.business-profile",
      "inversedBy": "favBusinessProfiles"
    },
    "favBusinessProfiles": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::business-profile.business-profile",
      "mappedBy": "businessProfiles"
    }
  }
}
